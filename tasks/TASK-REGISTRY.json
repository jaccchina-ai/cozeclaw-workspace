    {
      "id": "T01",
      "name": "A股龙头选股策略",
      "version": "1.0.0",
      "status": "active",
      "priority": "high",
      "category": "quantitative-trading",
      "createdAt": "2026-03-02T00:00:00.000Z",
      "updatedAt": "2026-03-02T00:00:00.000Z",
      "owner": "user",
      "objective": {
        "summary": "基于涨停板策略的A股龙头股选股系统，在交易日T日晚间和T+1日早盘进行两次筛选，推荐最有望继续涨停的股票",
        "workflow": [
          {
            "step": 1,
            "name": "交易日判断",
            "description": "根据交易日历判断某一天是否是交易日",
            "timing": "任意时间",
            "dataRequired": ["交易日历"]
          },
          {
            "step": 2,
            "name": "T日晚间初步筛选",
            "description": "T日晚上8:00对当日涨停股做初步评分，筛选出有望在T+1日继续涨停概率最高的10只股票作为观察标的",
            "timing": "T日 20:00",
            "dataRequired": ["涨停股列表", "涨停原因", "板块信息", "资金流向"],
            "outputs": ["10只观察标的", "判断理由", "热门板块分析", "宏观风险分析"]
          },
          {
            "step": 3,
            "name": "T+1日早盘最终推荐",
            "description": "T+1日早上9:25获取竞价数据后对T日晚间选出的观察标的做进一步分析，结合大盘风险、宏观风险等给出当天继续涨停概率最高的3只股票",
            "timing": "T+1日 09:25",
            "dataRequired": ["竞价数据", "大盘走势", "板块热度", "资金动向"],
            "outputs": ["3只推荐股票", "仓位建议", "判断理由", "风险提示"]
          }
        ]
      },
      "configuration": {
        "tradingCalendar": {
          "source": "tushare",
          "apiEndpoint": "trade_cal",
          "cacheEnabled": true,
          "cacheExpiry": "1d"
        },
        "eveningScreening": {
          "time": "20:00",
          "limitStocks": 10,
          "timezone": "Asia/Shanghai"
        },
        "morningSelection": {
          "time": "09:25",
          "finalPicks": 3,
          "timezone": "Asia/Shanghai"
        }
      },
